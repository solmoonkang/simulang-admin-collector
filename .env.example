# .env.example → .env 로 복사 후 실제 값 입력  (.env 는 .gitignore 로 제외됨)

# ── 대상 사이트 / 계정 ──
SITE_URL=https://your-admin-site.example.com
LOGIN_ID=your_login_id
LOGIN_PW=your_password

# ── 로그인 폼 셀렉터 (macOS '손쉬운 사용 검사기'로 확인; 사이트마다 다름) ──
SEL_ID_NAME=ID 입력칸의 접근성 이름
SEL_PW_TYPE=보안 텍스트 필드
SEL_LOGIN_BTN=로그인 버튼 이름

# ── 수집 대상 ──
MENUS=메뉴1,메뉴2,메뉴3
DATA_PATH=/admin/list

# ── 비전(표 OCR) 방식 설정 ──
COLUMNS=열1,열2,열3
ROW_ANCHOR_REGEX=\d{10}

# ── 출력 경로(레포 바깥). 비우면 ~/collector-output ──
# OUTPUT_DIR=/path/outside/repo
